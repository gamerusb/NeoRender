# Скопируйте в .env и подставьте значения. Файл .env загружается при старте api_server.
# Поверх .env применяется data/neo_settings.json (создаётся из UI при сохранении ключей).

GROQ_API_KEY=

# Data API v3: поиск Shorts в модуле контента (content_scraper)
YOUTUBE_API_KEY=

# Локальный API AdsPower (часто 50325; у вас может быть другой порт)
ADSPOWER_API_URL=http://127.0.0.1:50325
ADSPOWER_API_KEY=
ADSPOWER_USE_AUTH=0

# Опционально: сразу рендерить через CPU (libx264), без NVENC
# NEORENDER_DISABLE_NVENC=1

# FFmpeg в PATH или полный путь
# FFMPEG_PATH=ffmpeg
# FFPROBE_PATH=ffprobe

# Разброс уникализации по умолчанию для нового пайплайна: low | med | high (можно сменить в UI).
# NEORENDER_UNIQUIZE_INTENSITY=med

# Макс. секунд на один проход кодирования FFmpeg (по умолчанию 14400 = 4 ч). 0 = без лимита.
# NEORENDER_FFMPEG_TIMEOUT_SEC=14400

# Свой путь к JSON настроек вместо data/neo_settings.json
# NEORENDER_SETTINGS_PATH=

# Авто-ретрай задач при ошибках AdsPower/YouTube (0 = выключено, default 3)
# NEORENDER_MAX_RETRIES=3

# Количество параллельных воркеров пайплайна (default 1).
# Для сценария "10 видео → 10 аккаунтов" рекомендуется 2-3.
# Каждый профиль AdsPower защищён мьютексом — два воркера не откроют один профиль одновременно.
# NEORENDER_WORKERS=2

# Очистка отрендеренных файлов после успешного залива на YouTube (default выключено)
# NEORENDER_CLEANUP_ON_SUCCESS=1
